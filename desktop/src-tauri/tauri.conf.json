{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RoleRover Desktop",
  "version": "0.1.0",
  "identifier": "com.rolerover.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RoleRover Desktop",
        "width": 1480,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "dangerousInsecureTransportProtocol": true,
      "endpoints": [
        "http://127.0.0.1:8765/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdEQ0Y2OUQ0Mjk4Q0U0MjQKUldRazVJd3AxR25QZll1cFgrSXFMZ0RNR1BvcmZ1Y25qcE5kc2JNclRhYjFXOEhHTC9uNHYvam4K",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ]
  }
}
